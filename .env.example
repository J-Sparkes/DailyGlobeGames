# Public site URL (used in share links)
NEXT_PUBLIC_SITE_URL=https://dailyglobegames.com

# Supabase (required for accounts, leaderboards, friends)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Development only — leave unset in production
# NEXT_PUBLIC_UNLIMITED_PLAYS=true

# Daily reminder emails (optional)
RESEND_API_KEY=
RESEND_FROM=Daily Globe Games <reminders@dailyglobegames.com>
CRON_SECRET=

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=dailyglobegames.com

# Supporter tip jar (optional — Ko-fi, Buy Me a Coffee, etc.)
NEXT_PUBLIC_SUPPORT_URL=

# Stripe Premium / archive (optional)
STRIPE_SECRET_KEY=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
