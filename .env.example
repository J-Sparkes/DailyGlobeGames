# Public site URL (used in share links)
NEXT_PUBLIC_SITE_URL=https://dailygeography.app

# Supabase (required for accounts, leaderboards, friends)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Development only — leave unset in production
# NEXT_PUBLIC_UNLIMITED_PLAYS=true
